<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>我的相册</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;background:#121212;color:#e0e0e0;min-height:100vh}
/* Header */
header{text-align:center;padding:32px 16px 16px}
header h1{font-size:24px;font-weight:700;letter-spacing:1px;color:#fff}
header p{font-size:14px;color:#888;margin-top:6px}
/* Gallery Grid */
.gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;padding:16px;max-width:1400px;margin:0 auto}
.gallery-item{position:relative;border-radius:10px;overflow:hidden;cursor:pointer;aspect-ratio:4/3;background:#1e1e1e;transition:transform .2s}
.gallery-item:hover{transform:scale(1.02)}
.gallery-item img,.gallery-item video{width:100%;height:100%;object-fit:cover;display:block}
.gallery-item .play-btn{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:56px;height:56px;background:rgba(0,0,0,0.6);border-radius:50%;display:flex;align-items:center;justify-content:center;pointer-events:none;opacity:0;transition:opacity .2s}
.gallery-item .play-btn.show{opacity:1}
.gallery-item .play-btn svg{width:24px;height:24px;fill:#fff;margin-left:3px}
.gallery-item .video-duration{position:absolute;bottom:6px;right:8px;background:rgba(0,0,0,0.7);color:#fff;font-size:12px;padding:2px 6px;border-radius:4px;opacity:0;transition:opacity .2s}
.gallery-item .video-duration.show{opacity:1}
.gallery-item .loading{position:absolute;inset:0;background:linear-gradient(90deg,#1e1e1e 25%,#2a2a2a 50%,#1e1e1e 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
/* Lightbox */
#lightbox{display:none;position:fixed;inset:0;z-index:999;background:rgba(0,0,0,0.95);justify-content:center;align-items:center;flex-direction:column;backdrop-filter:blur(8px);touch-action:none}
#lightbox.open{display:flex}
#lightbox .close,#lightbox .nav{position:fixed;z-index:1001;color:#fff;cursor:pointer;user-select:none;display:flex;align-items:center;justify-content:center}
#lightbox .close{top:16px;right:16px;width:40px;height:40px;font-size:28px;background:rgba(255,255,255,0.1);border-radius:50%;transition:background .2s}
#lightbox .close:hover{background:rgba(255,255,255,0.2)}
#lightbox .nav{top:50%;transform:translateY(-50%);width:44px;height:44px;font-size:36px;border-radius:50%;background:rgba(255,255,255,0.05);transition:background .2s}
#lightbox .nav:hover{background:rgba(255,255,255,0.15)}
#lightbox .prev{left:16px}
#lightbox .next{right:16px}
#lightbox .counter{position:fixed;top:16px;left:50%;transform:translateX(-50%);color:#aaa;font-size:14px;z-index:1001}
#lightbox-content{display:flex;align-items:center;justify-content:center;width:100%;height:100%;padding:60px 48px}
#lightbox-content img,#lightbox-content video{max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;box-shadow:0 8px 40px rgba(0,0,0,0.5)}
#lightbox-content video{width:auto;height:auto;max-width:100%;max-height:100%}
#lightbox-content video::-webkit-media-controls{pointer-events:auto}
/* Watermark */
#lightbox .watermark{position:fixed;bottom:24px;right:24px;z-index:1001;color:rgba(255,255,255,0.25);font-size:13px;font-weight:300;letter-spacing:1px;pointer-events:none;transform:rotate(-12deg);text-shadow:0 1px 3px rgba(0,0,0,0.4);user-select:none;white-space:nowrap}
/* No photos */
.no-photos{text-align:center;padding:80px 16px;color:#666;font-size:16px}
.no-photos code{background:#1e1e1e;padding:2px 8px;border-radius:4px;font-size:13px}
/* Responsive */
@media(max-width:640px){header h1{font-size:20px}.gallery{grid-template-columns:repeat(2,1fr);gap:6px;padding:8px}.gallery-item{border-radius:6px}#lightbox-content{padding:48px 12px}#lightbox .prev{left:8px}#lightbox .next{right:8px}#lightbox .nav{width:36px;height:36px;font-size:28px}}
</style>
</head>
<body>

<header>
  <h1 id="album-title">我的相册</h1>
  <p id="photo-count"></p>
</header>

<main class="gallery" id="gallery"></main>

<div id="lightbox" role="dialog" aria-label="图片浏览">
  <span class="close" id="lb-close">&times;</span>
  <span class="nav prev" id="lb-prev">&lsaquo;</span>
  <span class="nav next" id="lb-next">&rsaquo;</span>
  <span class="counter" id="lb-counter"></span>
  <div id="lightbox-content"></div>
  <span class="watermark" id="lb-watermark">&copy; My Album</span>
</div>

<script>
// ════════════════════════════════════════════════════
//  ✏️  在这里修改：相册标题、水印文字、照片列表
// ════════════════════════════════════════════════════

const ALBUM_TITLE = '我的相册'
const WATERMARK_TEXT = '\u00A9 My Album'
const PHOTOS = [
  // 照片（32 张）
  'photo-01.jpg', 'photo-02.jpg', 'photo-03.jpg', 'photo-04.jpg',
  'photo-05.jpg', 'photo-06.jpg', 'photo-07.jpg', 'photo-08.jpg',
  'photo-09.jpg', 'photo-10.jpg', 'photo-11.jpg', 'photo-12.jpg',
  'photo-13.jpg', 'photo-14.jpg', 'photo-15.jpg', 'photo-16.jpg',
  'photo-17.jpg', 'photo-18.jpg', 'photo-19.jpg', 'photo-20.jpg',
  'photo-21.jpg', 'photo-22.jpg', 'photo-23.jpg', 'photo-24.jpg',
  'photo-25.jpg', 'photo-26.jpg', 'photo-27.jpg', 'photo-28.jpg',
  'photo-29.jpg', 'photo-30.jpg', 'photo-31.jpg', 'photo-32.jpg',
  // 视频（2 个）
  'video-01.mp4', 'video-02.mp4',
]

// ════════════════════════════════════════════════════
//  以下为相册逻辑，无需修改
// ════════════════════════════════════════════════════

const VIDEO_EXTS = ['mp4','webm','mov','avi']
const isVideo = src => VIDEO_EXTS.includes(src.split('.').pop().toLowerCase())
const pad = (n, w=2) => String(n).padStart(w, '0')
const $ = id => document.getElementById(id)

const albumTitle = $('album-title')
const photoCount = $('photo-count')
const gallery = $('gallery')
const lightbox = $('lightbox')
const lbContent = $('lightbox-content')
const lbCounter = $('lb-counter')
const lbWatermark = $('lb-watermark')

albumTitle.textContent = ALBUM_TITLE
lbWatermark.textContent = WATERMARK_TEXT

const items = PHOTOS.map((src, i) => ({
  src: `photos/${src}`,
  type: isVideo(src) ? 'video' : 'image',
  index: i
}))

const photoTotal = items.filter(i => i.type === 'image').length
const videoTotal = items.filter(i => i.type === 'video').length
const parts = []
if (photoTotal) parts.push(photoTotal + '\u5F20\u7167\u7247')
if (videoTotal) parts.push(videoTotal + '\u4E2A\u89C6\u9891')
photoCount.textContent = parts.length ? '\u5171 ' + parts.join('\uFF0C') : ''

// Render gallery
if (!items.length) {
  gallery.innerHTML = '<div class="no-photos">\u5C06\u7167\u7247\u653E\u5165 <code>photos/</code> \u6587\u4EF6\u5939\uFF0C\u5E76\u5728 <code>PHOTOS</code> \u6570\u7EC4\u4E2D\u6DFB\u52A0\u6587\u4EF6\u540D</div>'
} else {
  gallery.innerHTML = items.map((item, idx) => {
    const isVid = item.type === 'video'
    const placeholder = 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 4 3"%3E%3C/svg%3E'
    return `<div class="gallery-item" data-index="${idx}">
      <div class="loading"></div>
      ${isVid
        ? `<video preload="metadata" muted playsinline data-src="${item.src}"></video>`
        : `<img src="${placeholder}" data-src="${item.src}" alt="" loading="lazy">`
      }
      ${isVid ? `<div class="play-btn show"><svg viewBox="0 0 24 24"><polygon points="8,5 19,12 8,19"/></svg></div>
      <span class="video-duration show">&#9654; \u89C6\u9891</span>` : ''}
    </div>`
  }).join('')
}

// Lazy load with IntersectionObserver
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return
    const card = entry.target
    const loader = card.querySelector('.loading')
    const img = card.querySelector('img')
    const vid = card.querySelector('video')
    if (img && img.dataset.src) {
      const realImg = new Image()
      realImg.onload = () => { img.src = realImg.src; if (loader) loader.style.display = 'none' }
      realImg.onerror = () => { img.src = realImg.src; if (loader) loader.style.display = 'none' }
      realImg.src = img.dataset.src
      img.removeAttribute('data-src')
    }
    if (vid && vid.dataset.src) {
      vid.src = vid.dataset.src
      vid.load()
      vid.removeAttribute('data-src')
      if (loader) loader.style.display = 'none'
    }
    observer.unobserve(card)
  })
}, { rootMargin: '200px' })

document.querySelectorAll('.gallery-item').forEach(el => observer.observe(el))

// Lightbox
let currentIndex = 0

function openLightbox(index) {
  currentIndex = index
  lightbox.classList.add('open')
  renderLightboxContent()
  document.body.style.overflow = 'hidden'
}

function closeLightbox() {
  lightbox.classList.remove('open')
  document.body.style.overflow = ''
  const v = lbContent.querySelector('video')
  if (v) v.pause()
}

function goPrev() {
  currentIndex = (currentIndex - 1 + items.length) % items.length
  renderLightboxContent()
}

function goNext() {
  currentIndex = (currentIndex + 1) % items.length
  renderLightboxContent()
}

function getMimeType(src) {
  const ext = src.split('.').pop().toLowerCase()
  const map = { mp4:'video/mp4', webm:'video/webm', mov:'video/quicktime', avi:'video/x-msvideo' }
  return map[ext] || 'video/mp4'
}

function renderLightboxContent() {
  const item = items[currentIndex]
  lbCounter.textContent = `${currentIndex + 1} / ${items.length}`
  lbContent.innerHTML = item.type === 'video'
    ? `<video controls autoplay preload="metadata"><source src="${item.src}" type="${getMimeType(item.src)}"></video>`
    : `<img src="${item.src}" alt="">`
}

// Click to open
gallery.addEventListener('click', (e) => {
  const card = e.target.closest('.gallery-item')
  if (!card) return
  openLightbox(parseInt(card.dataset.index))
})

// Lightbox controls
$('lb-close').addEventListener('click', closeLightbox)
$('lb-prev').addEventListener('click', goPrev)
$('lb-next').addEventListener('click', goNext)

document.addEventListener('keydown', (e) => {
  if (!lightbox.classList.contains('open')) return
  if (e.key === 'Escape') closeLightbox()
  if (e.key === 'ArrowLeft') goPrev()
  if (e.key === 'ArrowRight') goNext()
})

lightbox.addEventListener('click', (e) => {
  if (e.target === lightbox) closeLightbox()
})

// Touch swipe
let touchStartX = 0
let touchEndX = 0

lightbox.addEventListener('touchstart', (e) => {
  if (e.target.closest('.nav') || e.target.closest('.close') || e.target.closest('video')) return
  touchStartX = e.changedTouches[0].screenX
}, { passive: true })

lightbox.addEventListener('touchend', (e) => {
  if (e.target.closest('.nav') || e.target.closest('.close') || e.target.closest('video')) return
  touchEndX = e.changedTouches[0].screenX
  const diff = touchStartX - touchEndX
  if (Math.abs(diff) > 50) {
    diff > 0 ? goNext() : goPrev()
  }
}, { passive: true })
</script>
</body>
</html>
